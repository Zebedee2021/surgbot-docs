<!-- instruments.xml - Surgical instruments on a tray
     4 instruments with free joints, on a fixed tray.
     Positions are relative to the tray body origin.
     Units: meters -->
<mujoco model="instruments">
  <!-- Instrument tray (200x150x5 mm, light blue surgical drape color) -->
  <body name="instrument_tray" pos="0.295 -0.113 0">
    <geom name="tray_surface" type="box" size="0.1 0.075 0.0025"
          mass="0.2" rgba="0.6 0.75 0.85 1" friction="0.8 0.3 0.001"/>

    <!-- Tray legs / support -->
    <geom name="tray_leg1" type="cylinder" size="0.008 0.01"
          pos="-0.08 -0.06 -0.0125" rgba="0.5 0.5 0.5 1"/>
    <geom name="tray_leg2" type="cylinder" size="0.008 0.01"
          pos="0.08 -0.06 -0.0125" rgba="0.5 0.5 0.5 1"/>
    <geom name="tray_leg3" type="cylinder" size="0.008 0.01"
          pos="-0.08 0.06 -0.0125" rgba="0.5 0.5 0.5 1"/>
    <geom name="tray_leg4" type="cylinder" size="0.008 0.01"
          pos="0.08 0.06 -0.0125" rgba="0.5 0.5 0.5 1"/>

    <!-- Instrument 0: Scalpel handle (刀柄)
         Position from instruments.ini: [250.5, -120.3, -85.2, 45.0] mm
         Relative to tray: offset from tray center -->
    <body name="scalpel_handle" pos="-0.0445 -0.0073 0.005">
      <joint name="scalpel_free" type="free"/>
      <geom name="scalpel_body" type="cylinder" size="0.005 0.06"
            mass="0.05" rgba="0.75 0.75 0.78 1"
            euler="0 1.5708 0.7854" friction="1 0.3 0.001"/>
      <!-- Blade end indicator -->
      <geom name="scalpel_blade" type="box" size="0.002 0.015 0.001"
            pos="0.055 0 0" mass="0.005" rgba="0.85 0.85 0.88 1"
            euler="0 1.5708 0.7854"/>
    </body>

    <!-- Instrument 1: Tweezers (镊子)
         Position: [280.1, -95.7, -82.0, 30.0] mm -->
    <body name="tweezers" pos="-0.0149 0.0173 0.005">
      <joint name="tweezers_free" type="free"/>
      <geom name="tweezers_body" type="capsule" size="0.002 0.07"
            mass="0.03" rgba="0.75 0.75 0.78 1"
            euler="0 1.5708 0.5236" friction="1 0.3 0.001"/>
    </body>

    <!-- Instrument 2: Scissors (剪刀)
         Position: [310.3, -130.5, -80.5, 60.0] mm -->
    <body name="scissors" pos="0.0153 -0.0175 0.005">
      <joint name="scissors_free" type="free"/>
      <geom name="scissors_body" type="capsule" size="0.003 0.06"
            mass="0.06" rgba="0.75 0.75 0.78 1"
            euler="0 1.5708 1.0472" friction="1 0.3 0.001"/>
      <!-- Ring handles -->
      <geom name="scissors_ring1" type="cylinder" size="0.012 0.002"
            pos="-0.055 0 0" mass="0.005" rgba="0.7 0.7 0.73 1"
            euler="0 1.5708 1.0472"/>
      <geom name="scissors_ring2" type="cylinder" size="0.012 0.002"
            pos="-0.05 0.005 0" mass="0.005" rgba="0.7 0.7 0.73 1"
            euler="0 1.5708 1.0472"/>
    </body>

    <!-- Instrument 3: Needle holder (持针钳)
         Position: [340.0, -110.2, -83.0, 15.0] mm -->
    <body name="needle_holder" pos="0.045 0.0028 0.005">
      <joint name="needle_holder_free" type="free"/>
      <geom name="needle_holder_body" type="capsule" size="0.004 0.065"
            mass="0.07" rgba="0.75 0.75 0.78 1"
            euler="0 1.5708 0.2618" friction="1 0.3 0.001"/>
      <!-- Ratchet handle -->
      <geom name="needle_holder_ring" type="cylinder" size="0.013 0.002"
            pos="-0.06 0 0" mass="0.005" rgba="0.7 0.7 0.73 1"
            euler="0 1.5708 0.2618"/>
    </body>
  </body>
</mujoco>
