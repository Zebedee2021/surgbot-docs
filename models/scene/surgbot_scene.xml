<!-- surgbot_scene.xml - Complete MuJoCo simulation scene
     Dobot CR5 + DH-3 gripper + 2 trays + 2 cameras + surgical instruments
     Layout based on 雄安现场测试 Figure 1:
       - Robot arm base at rear of table (origin)
       - Both trays in FRONT of arm (+X direction), side by side
       - Instrument tray: front-left  (+X, -Y)
       - Bed-end tray:    front-right (+X, +Y)
       - Camera 1 watches instrument tray (elevated)
       - Camera 2 watches bed-end tray (elevated)
       - Arm swings J1 ≈ ±27° to reach each tray
     Units: meters, radians, kg
     Coordinate system: Z-up, +X = arm forward direction -->
<mujoco model="surgbot_v2">
  <compiler angle="radian" meshdir="../cr5/meshes"/>

  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicit"/>

  <default>
    <joint damping="5"/>
    <geom condim="4" friction="1 0.5 0.005"/>
    <default class="visual">
      <geom contype="0" conaffinity="0" group="1"/>
    </default>
  </default>

  <asset>
    <!-- CR5 meshes -->
    <mesh name="base_link" file="base_link.stl"/>
    <mesh name="Link1" file="Link1.stl"/>
    <mesh name="Link2" file="Link2.stl"/>
    <mesh name="Link3" file="Link3.stl"/>
    <mesh name="Link4" file="Link4.stl"/>
    <mesh name="Link5" file="Link5.stl"/>
    <mesh name="Link6" file="Link6.stl"/>
    <!-- Materials -->
    <material name="steel" rgba="0.75 0.75 0.78 1"/>
    <material name="dark_metal" rgba="0.2 0.2 0.2 1"/>
    <material name="table_green" rgba="0.3 0.5 0.3 1"/>
    <material name="inst_tray_blue" rgba="0.6 0.78 0.92 1"/>
    <material name="inst_tray_edge" rgba="0.45 0.65 0.8 1"/>
    <material name="bed_tray_pink" rgba="0.92 0.72 0.72 1"/>
    <material name="bed_tray_edge" rgba="0.8 0.55 0.55 1"/>
    <material name="gripper_blue" rgba="0.2 0.45 0.75 1"/>
    <material name="rubber_black" rgba="0.1 0.1 0.1 1"/>
    <material name="camera_dark" rgba="0.15 0.15 0.18 1"/>
    <material name="lens_glass" rgba="0.05 0.05 0.1 1"/>
    <material name="bed_blue" rgba="0.6 0.7 0.85 1"/>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.9 0.9 0.9" rgb2="0.8 0.8 0.8"/>
    <material name="floor_mat" texture="grid" texrepeat="10 10"/>
  </asset>

  <worldbody>
    <!-- Lighting -->
    <light name="top_light" pos="0 0 2.5" dir="0 0 -1" diffuse="0.8 0.8 0.8"
           specular="0.3 0.3 0.3" directional="true"/>
    <light name="front_light" pos="1 -1 2" dir="-0.5 0.5 -1" diffuse="0.4 0.4 0.4"/>

    <!-- Ground plane -->
    <geom name="floor" type="plane" size="3 3 0.01" material="floor_mat"
          conaffinity="1" condim="3"/>

    <!-- ============================================ -->
    <!-- Operating table (surface at z=0.75m)         -->
    <!-- Extended forward (+X) for tray workspace     -->
    <!-- ============================================ -->
    <body name="table" pos="0.15 0 0.73">
      <geom name="table_top" type="box" size="0.55 0.45 0.02"
            material="table_green" mass="25"/>
      <geom name="table_leg1" type="cylinder" size="0.03 0.355"
            pos="-0.5 -0.4 -0.375" rgba="0.5 0.5 0.5 1"/>
      <geom name="table_leg2" type="cylinder" size="0.03 0.355"
            pos="0.5 -0.4 -0.375" rgba="0.5 0.5 0.5 1"/>
      <geom name="table_leg3" type="cylinder" size="0.03 0.355"
            pos="-0.5 0.4 -0.375" rgba="0.5 0.5 0.5 1"/>
      <geom name="table_leg4" type="cylinder" size="0.03 0.355"
            pos="0.5 0.4 -0.375" rgba="0.5 0.5 0.5 1"/>
    </body>

    <!-- ============================================ -->
    <!-- Hospital Bed (simplified, far +X side)       -->
    <!-- Surgeon side, beyond the trays               -->
    <!-- ============================================ -->
    <body name="hospital_bed" pos="0.95 0 0.4">
      <geom name="bed_surface" type="box" size="0.35 0.9 0.04"
            material="bed_blue" mass="30"/>
      <geom name="bed_leg1" type="cylinder" size="0.025 0.18"
            pos="-0.3 -0.8 -0.22" rgba="0.4 0.4 0.4 1"/>
      <geom name="bed_leg2" type="cylinder" size="0.025 0.18"
            pos="0.3 -0.8 -0.22" rgba="0.4 0.4 0.4 1"/>
      <geom name="bed_leg3" type="cylinder" size="0.025 0.18"
            pos="-0.3 0.8 -0.22" rgba="0.4 0.4 0.4 1"/>
      <geom name="bed_leg4" type="cylinder" size="0.025 0.18"
            pos="0.3 0.8 -0.22" rgba="0.4 0.4 0.4 1"/>
    </body>

    <!-- ============================================ -->
    <!-- CR5 Robot Arm (base on table center, z=0.76) -->
    <!-- ============================================ -->
    <body name="cr5_base" pos="0 0 0.76">
      <geom type="mesh" rgba="0 0 0 1" mesh="base_link"/>

      <body name="Link1" pos="0 0 0.147">
        <inertial pos="-8.7268e-07 -0.0032576 -0.0076748"
                  quat="0.615786 0.347596 -0.347595 0.615761"
                  mass="1.6123"
                  diaginertia="0.00354972 0.0029122 0.00255298"/>
        <joint name="joint1" pos="0 0 0" axis="0 0 1"
               range="-3.14 3.14" damping="10"/>
        <geom type="mesh" rgba="1 1 1 1" mesh="Link1"/>

        <body name="Link2" quat="0.499998 0.5 0.5 -0.500002">
          <inertial pos="-0.21351 -1.3842e-06 0.14252"
                    quat="8.38738e-05 0.707093 5.56955e-05 0.707121"
                    mass="5.5186"
                    diaginertia="0.028294 0.027553 0.0085919"/>
          <joint name="joint2" pos="0 0 0" axis="0 0 1"
                 range="-3.14 3.14" damping="10"/>
          <geom type="mesh" rgba="1 1 1 1" mesh="Link2"/>

          <body name="Link3" pos="-0.427 0 0">
            <inertial pos="-0.15231 -1.4079e-07 0.022693"
                      quat="0 0.714013 0 0.700132"
                      mass="2.8536"
                      diaginertia="0.00955763 0.0092967 0.00325837"/>
            <joint name="joint3" pos="0 0 0" axis="0 0 1"
                   range="-2.86 2.86" damping="8"/>
            <geom type="mesh" rgba="1 1 1 1" mesh="Link3"/>

            <body name="Link4" pos="-0.357 0 0.141"
                  quat="0.707105 0 0 -0.707108">
              <inertial pos="-3.2386e-07 -0.002077 -0.0015548"
                        quat="0.653428 0.270173 -0.270153 0.653495"
                        mass="0.67058"
                        diaginertia="0.000764755 0.00066939 0.000543135"/>
              <joint name="joint4" pos="0 0 0" axis="0 0 1"
                     range="-3.14 3.14" damping="5"/>
              <geom type="mesh" rgba="1 1 1 1" mesh="Link4"/>

              <body name="Link5" pos="0 -0.116 0"
                    quat="0.707105 0.707108 0 0">
                <inertial pos="-3.7738e-07 -0.0045777 -0.0012971"
                          quat="0.27195 0.652753 -0.652695 0.271929"
                          mass="0.7269"
                          diaginertia="0.000832194 0.00073069 0.000593666"/>
                <joint name="joint5" pos="0 0 0" axis="0 0 1"
                       range="-3.14 3.14" damping="5"/>
                <geom type="mesh" rgba="1 1 1 1" mesh="Link5"/>

                <body name="Link6" pos="0 0.105 0"
                      quat="0.707105 -0.707108 0 0">
                  <inertial pos="5.0777e-11 9.3774e-05 -0.019285"
                            quat="-0.000970713 0.707106 -0.000970713 0.707106"
                            mass="0.15789"
                            diaginertia="0.00012951 7.91676e-05 7.8045e-05"/>
                  <joint name="joint6" pos="0 0 0" axis="0 0 1"
                         range="-6.28 6.28" damping="3"/>
                  <geom type="mesh" rgba="1 1 1 1" mesh="Link6"/>
                  <site name="ee_site" pos="0 0 0" size="0.01" rgba="1 0 0 0.5"/>

                  <!-- ======== DH-3 Gripper (mounted on Link6) ======== -->
                  <geom name="gripper_flange" type="cylinder" size="0.032 0.015"
                        pos="0 0 0.015" rgba="0.25 0.25 0.25 1"/>

                  <body name="gripper_base" pos="0 0 0.045">
                    <geom name="gripper_housing" type="box" size="0.06 0.045 0.02"
                          mass="0.3" material="gripper_blue"/>
                    <geom name="gripper_stripe" type="box" size="0.055 0.002 0.021"
                          pos="0 0 0" rgba="0.9 0.9 0.9 1"
                          contype="0" conaffinity="0"/>

                    <body name="gripper_left_finger" pos="0 0.02 0.02">
                      <joint name="gripper_left" type="slide" axis="0 1 0"
                             range="0 0.03" damping="2"/>
                      <geom name="gripper_left_bracket" type="box"
                            size="0.015 0.012 0.015" pos="0 0 0.01"
                            mass="0.02" rgba="0.6 0.6 0.6 1"/>
                      <geom name="gripper_left_body" type="box"
                            size="0.015 0.012 0.04" pos="0 0 0.055"
                            mass="0.05" rgba="0.85 0.15 0.1 1"/>
                      <body name="gripper_left_pad" pos="0 -0.012 0.085">
                        <geom name="left_pad" type="box"
                              size="0.014 0.005 0.015" mass="0.01"
                              material="rubber_black"
                              friction="2 0.5 0.005" condim="4"/>
                        <site name="left_pad_site" pos="0 0 0" size="0.005"/>
                      </body>
                    </body>

                    <body name="gripper_right_finger" pos="0 -0.02 0.02">
                      <joint name="gripper_right" type="slide" axis="0 -1 0"
                             range="0 0.03" damping="2"/>
                      <geom name="gripper_right_bracket" type="box"
                            size="0.015 0.012 0.015" pos="0 0 0.01"
                            mass="0.02" rgba="0.6 0.6 0.6 1"/>
                      <geom name="gripper_right_body" type="box"
                            size="0.015 0.012 0.04" pos="0 0 0.055"
                            mass="0.05" rgba="0.85 0.15 0.1 1"/>
                      <body name="gripper_right_pad" pos="0 0.012 0.085">
                        <geom name="right_pad" type="box"
                              size="0.014 0.005 0.015" mass="0.01"
                              material="rubber_black"
                              friction="2 0.5 0.005" condim="4"/>
                        <site name="right_pad_site" pos="0 0 0" size="0.005"/>
                      </body>
                    </body>

                    <site name="gripper_tcp" pos="0 0 0.1"
                          size="0.002" rgba="1 1 0 0.3"/>
                  </body>
                  <!-- ======== End Gripper ======== -->

                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
    <!-- End CR5 Robot Arm -->

    <!-- ============================================ -->
    <!-- Camera 1: Watches Instrument Tray (front-left)-->
    <!-- Elevated stand behind inst tray, angled down  -->
    <!-- ============================================ -->
    <body name="camera_stand_1" pos="0.6 -0.2 0">
      <geom name="cam1_pole" type="cylinder" size="0.012 0.68"
            pos="0 0 0.68" rgba="0.35 0.35 0.35 1"/>
      <geom name="cam1_bracket" type="box" size="0.012 0.1 0.012"
            pos="0 -0.08 1.36" rgba="0.35 0.35 0.35 1"/>
      <body name="camera_head_1" pos="0 -0.17 1.34" euler="1.1 0 -0.3">
        <geom name="cam1_housing" type="box" size="0.045 0.0125 0.0125"
              material="camera_dark"/>
        <geom name="cam1_lens_L" type="cylinder" size="0.005 0.004"
              pos="-0.028 -0.017 0" euler="1.5708 0 0"
              material="lens_glass" contype="0" conaffinity="0"/>
        <geom name="cam1_lens_R" type="cylinder" size="0.005 0.004"
              pos="0.028 -0.017 0" euler="1.5708 0 0"
              material="lens_glass" contype="0" conaffinity="0"/>
        <geom name="cam1_lens_C" type="cylinder" size="0.004 0.004"
              pos="0 -0.017 0" euler="1.5708 0 0"
              rgba="0.1 0.1 0.3 1" contype="0" conaffinity="0"/>
        <site name="camera1_site" pos="0 -0.02 0" size="0.003"/>
      </body>
      <geom name="cam1_label" type="box" size="0.03 0.002 0.01"
            pos="0 0 1.39" rgba="1 0.9 0.3 1"
            contype="0" conaffinity="0"/>
    </body>

    <!-- ============================================ -->
    <!-- Camera 2: Watches Bed-end Tray (front-right) -->
    <!-- Elevated stand behind bed tray, angled down  -->
    <!-- ============================================ -->
    <body name="camera_stand_2" pos="0.6 0.2 0">
      <geom name="cam2_pole" type="cylinder" size="0.012 0.68"
            pos="0 0 0.68" rgba="0.35 0.35 0.35 1"/>
      <geom name="cam2_bracket" type="box" size="0.012 0.1 0.012"
            pos="0 0.08 1.36" rgba="0.35 0.35 0.35 1"/>
      <body name="camera_head_2" pos="0 0.17 1.34" euler="1.1 0 0.3">
        <geom name="cam2_housing" type="box" size="0.045 0.0125 0.0125"
              material="camera_dark"/>
        <geom name="cam2_lens_L" type="cylinder" size="0.005 0.004"
              pos="-0.028 -0.017 0" euler="1.5708 0 0"
              material="lens_glass" contype="0" conaffinity="0"/>
        <geom name="cam2_lens_R" type="cylinder" size="0.005 0.004"
              pos="0.028 -0.017 0" euler="1.5708 0 0"
              material="lens_glass" contype="0" conaffinity="0"/>
        <geom name="cam2_lens_C" type="cylinder" size="0.004 0.004"
              pos="0 -0.017 0" euler="1.5708 0 0"
              rgba="0.1 0.1 0.3 1" contype="0" conaffinity="0"/>
        <site name="camera2_site" pos="0 -0.02 0" size="0.003"/>
      </body>
      <geom name="cam2_label" type="box" size="0.03 0.002 0.01"
            pos="0 0 1.39" rgba="0.3 0.9 0.5 1"
            contype="0" conaffinity="0"/>
    </body>

    <!-- ============================================ -->
    <!-- Instrument Tray (器械托盘, front-left)       -->
    <!-- +X,-Y: in front of arm, left side            -->
    <!-- On table surface, z=0.758                    -->
    <!-- ============================================ -->
    <body name="instrument_tray" pos="0.35 -0.15 0.758">
      <geom name="inst_tray_surface" type="box" size="0.13 0.1 0.004"
            mass="0.3" material="inst_tray_blue" friction="0.8 0.3 0.001"/>
      <geom name="inst_tray_front" type="box" size="0.13 0.003 0.0075"
            pos="0 -0.1 0.012" material="inst_tray_edge"/>
      <geom name="inst_tray_back" type="box" size="0.13 0.003 0.0075"
            pos="0 0.1 0.012" material="inst_tray_edge"/>
      <geom name="inst_tray_left" type="box" size="0.003 0.1 0.0075"
            pos="-0.13 0 0.012" material="inst_tray_edge"/>
      <geom name="inst_tray_right" type="box" size="0.003 0.1 0.0075"
            pos="0.13 0 0.012" material="inst_tray_edge"/>
      <geom name="inst_tray_label" type="box" size="0.025 0.008 0.001"
            pos="0.09 -0.08 0.005" rgba="0.2 0.4 0.7 1"
            contype="0" conaffinity="0"/>
    </body>

    <!-- ============================================ -->
    <!-- Bed-end Tray (床尾托盘, front-right)         -->
    <!-- +X,+Y: in front of arm, right side           -->
    <!-- On table surface, z=0.758                    -->
    <!-- ============================================ -->
    <body name="bed_tray" pos="0.35 0.15 0.758">
      <geom name="bed_tray_surface" type="box" size="0.13 0.1 0.004"
            mass="0.3" material="bed_tray_pink" friction="0.8 0.3 0.001"/>
      <geom name="bed_tray_front" type="box" size="0.13 0.003 0.0075"
            pos="0 -0.1 0.012" material="bed_tray_edge"/>
      <geom name="bed_tray_back" type="box" size="0.13 0.003 0.0075"
            pos="0 0.1 0.012" material="bed_tray_edge"/>
      <geom name="bed_tray_left" type="box" size="0.003 0.1 0.0075"
            pos="-0.13 0 0.012" material="bed_tray_edge"/>
      <geom name="bed_tray_right" type="box" size="0.003 0.1 0.0075"
            pos="0.13 0 0.012" material="bed_tray_edge"/>
      <geom name="bed_tray_label" type="box" size="0.025 0.008 0.001"
            pos="0.09 0.08 0.005" rgba="0.7 0.3 0.3 1"
            contype="0" conaffinity="0"/>
    </body>

    <!-- ============================================ -->
    <!-- 4 Surgical Instruments on Instrument Tray    -->
    <!-- Inst tray center: (0.35, -0.15, 0.758)      -->
    <!-- z=0.77 (above tray surface)                  -->
    <!-- ============================================ -->

    <!-- Instrument 0: Scalpel (刀柄) - YELLOW handle + silver blade -->
    <body name="scalpel_handle" pos="0.29 -0.19 0.77">
      <joint name="scalpel_free" type="free"/>
      <geom name="scalpel_shaft" type="cylinder" size="0.006 0.05"
            mass="0.04" rgba="0.9 0.8 0.2 1"
            euler="0 1.5708 0"/>
      <geom name="scalpel_blade" type="box" size="0.015 0.005 0.001"
            pos="0.04 0.025 0" mass="0.01" rgba="0.88 0.88 0.92 1"/>
    </body>

    <!-- Instrument 1: Tweezers (镊子) - GOLD/BRASS, twin prongs -->
    <body name="tweezers" pos="0.33 -0.11 0.77">
      <joint name="tweezers_free" type="free"/>
      <geom name="tweezers_arm1" type="capsule" size="0.002 0.06"
            pos="0 0.002 0" mass="0.015" rgba="0.8 0.7 0.3 1"
            euler="0 1.5708 0"/>
      <geom name="tweezers_arm2" type="capsule" size="0.002 0.06"
            pos="0 -0.002 0" mass="0.015" rgba="0.8 0.7 0.3 1"
            euler="0 1.5708 0"/>
    </body>

    <!-- Instrument 2: Scissors (剪刀) - silver + GREEN rings -->
    <body name="scissors" pos="0.37 -0.19 0.77">
      <joint name="scissors_free" type="free"/>
      <geom name="scissors_shaft" type="capsule" size="0.003 0.05"
            mass="0.04" rgba="0.78 0.78 0.82 1"
            euler="0 1.5708 0"/>
      <geom name="scissors_ring1" type="cylinder" size="0.013 0.003"
            pos="-0.04 -0.02 0" mass="0.01" rgba="0.2 0.65 0.35 1"/>
      <geom name="scissors_ring2" type="cylinder" size="0.013 0.003"
            pos="-0.035 -0.028 0" mass="0.01" rgba="0.2 0.65 0.35 1"/>
    </body>

    <!-- Instrument 3: Needle holder (持针钳) - BLUE handle + jaw -->
    <body name="needle_holder" pos="0.41 -0.11 0.77">
      <joint name="needle_holder_free" type="free"/>
      <geom name="needle_holder_shaft" type="capsule" size="0.004 0.055"
            mass="0.05" rgba="0.3 0.5 0.8 1"
            euler="0 1.5708 0"/>
      <geom name="needle_holder_jaw" type="box" size="0.018 0.005 0.002"
            pos="0.06 0.01 0" mass="0.01" rgba="0.78 0.78 0.82 1"/>
      <geom name="needle_holder_ring" type="cylinder" size="0.014 0.003"
            pos="-0.05 -0.01 0" mass="0.01" rgba="0.3 0.5 0.8 1"/>
    </body>
    <!-- End Instruments -->

  </worldbody>

  <!-- ============================================ -->
  <!-- Actuators: 6 arm joints + 2 gripper fingers  -->
  <!-- ============================================ -->
  <actuator>
    <position name="joint1_ctrl" joint="joint1" kp="200"
              ctrlrange="-3.14 3.14"/>
    <position name="joint2_ctrl" joint="joint2" kp="200"
              ctrlrange="-3.14 3.14"/>
    <position name="joint3_ctrl" joint="joint3" kp="150"
              ctrlrange="-2.86 2.86"/>
    <position name="joint4_ctrl" joint="joint4" kp="80"
              ctrlrange="-3.14 3.14"/>
    <position name="joint5_ctrl" joint="joint5" kp="80"
              ctrlrange="-3.14 3.14"/>
    <position name="joint6_ctrl" joint="joint6" kp="50"
              ctrlrange="-6.28 6.28"/>
    <position name="gripper_left_ctrl" joint="gripper_left" kp="50"
              ctrlrange="0 0.03"/>
    <position name="gripper_right_ctrl" joint="gripper_right" kp="50"
              ctrlrange="0 0.03"/>
  </actuator>

  <!-- Sensors -->
  <sensor>
    <force name="ee_force" site="ee_site"/>
    <torque name="ee_torque" site="ee_site"/>
    <touch name="left_pad_touch" site="left_pad_site"/>
    <touch name="right_pad_touch" site="right_pad_site"/>
  </sensor>

  <!-- Equality: gripper finger coupling -->
  <equality>
    <joint joint1="gripper_left" joint2="gripper_right" polycoef="0 1 0 0 0"/>
  </equality>

  <!-- ============================================ -->
  <!-- Keyframes                                    -->
  <!-- J1≈-0.46 faces inst tray (front-left)        -->
  <!-- J1≈+0.46 faces bed tray (front-right)        -->
  <!-- Both trays at +X, arm swings ±27° in Y       -->
  <!-- ============================================ -->
  <keyframe>
    <!-- Home / zero position -->
    <key name="home"
         qpos="0 0 0 0 0 0 0 0
               0.29 -0.19 0.77 1 0 0 0
               0.33 -0.11 0.77 1 0 0 0
               0.37 -0.19 0.77 1 0 0 0
               0.41 -0.11 0.77 1 0 0 0"
         ctrl="0 0 0 0 0 0 0.02 0.02"/>
    <!-- Reset: arm reaching toward instrument tray (front-left, J1=-27°) -->
    <key name="reset"
         qpos="-0.46 0.5691 -2.2532 0.1169 1.5708 -1.5708 0 0
               0.29 -0.19 0.77 1 0 0 0
               0.33 -0.11 0.77 1 0 0 0
               0.37 -0.19 0.77 1 0 0 0
               0.41 -0.11 0.77 1 0 0 0"
         ctrl="-0.46 0.5691 -2.2532 0.1169 1.5708 -1.5708 0.02 0.02"/>
    <!-- Target: arm reaching toward bed-end tray (front-right, J1=+27°) -->
    <key name="target"
         qpos="0.46 0.5691 -2.2532 0.1169 1.5708 -1.5708 0 0
               0.29 -0.19 0.77 1 0 0 0
               0.33 -0.11 0.77 1 0 0 0
               0.37 -0.19 0.77 1 0 0 0
               0.41 -0.11 0.77 1 0 0 0"
         ctrl="0.46 0.5691 -2.2532 0.1169 1.5708 -1.5708 0.02 0.02"/>
  </keyframe>
</mujoco>
